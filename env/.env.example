# Example environment variables for the food_delivery project
# Copy this file to `.env` and fill in real values.

# Django
DJANGO_DEBUG=False
SECRET_KEY=changeme
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Postgres)
DATABASE_URL=postgres://postgres:postgres@db:5432/food_delivery
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=food_delivery
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Cache / Broker
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=changeme
EMAIL_USE_TLS=True

# Frontend
FRONTEND_URL=http://localhost:3000

# Payments
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_API_URL=
PAYOS_RETURN_URL=
PAYOS_CANCEL_URL=

PAYOS_PAYOUT_CLIENT_ID=
PAYOS_PAYOUT_API_KEY=
PAYOS_PAYOUT_CHECKSUM_KEY=

GEMINI_API_KEY=
OTP_WITHDRAW_EXPIRE_MINUTES=
OTP_BANK_EXPIRE_MINUTES=
OTP_SIGNUP_EXPIRE_MINUTES=
OTP_RESET_PASSWORD_EXPIRE_MINUTES=
WALLET_CHAIN_SECRET=
